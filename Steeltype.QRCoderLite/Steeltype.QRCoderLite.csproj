<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<Version>2.0.0</Version>
		<Title>Steeltype.QRCoderLite</Title>
		<Description>A lightweight, zero-dependency QR code generator for .NET 8. Renders PNG, SVG (with optional logo), ASCII, Base64, BMP, and PDF output with no external dependencies, plus payload generators for WiFi, contacts, calendar events, OTP, and more.</Description>
		<Copyright>Copyright 2024-2026 Steeltype LLC, released under BSD-3-Clause</Copyright>
		<PackageReadmeFile>readme.md</PackageReadmeFile>
		<RepositoryUrl>https://github.com/Steeltype/QRCoderLite</RepositoryUrl>
		<PackageTags>qr;qrcode;qr-generator;qr-code-generator;png;svg;pdf;bmp;ascii;base64;zero-dependency;net8</PackageTags>
		<PackageReleaseNotes>2.0.0 — Breaking (vs 1.0.0): removed SkiaSharp dependency and with it the QRCode (Bitmap), ArtQRCode, and PostscriptQRCode renderers; removed nine payload generators (MMS, SkypeCall, SwissQrCode, Girocode, BezahlCode, ShadowSocksConfig, MoneroTransaction, SlovenianUpnQr, RussiaPaymentOrder); removed the obsolete OneTimePassword.Algorithm member, BitmapByteQRCodeHelper.GetQRCode(string, ECCLevel, int), the PdfByteQRCode jpgQuality parameter, and Base64QRCode Skia overloads (Base64 output is now 1-bit PNG); new hard input limits reject previously accepted values (pixelsPerModule 1-100 for PNG/BMP/ASCII and 1-1000 for SVG/PDF; PDF dpi 1-2400; SVG logo max 5 MB). New: SvgQRCode renderer (with logo support), WiFi WPA2 authentication, hardened QRCodeData raw-data deserialization (10 MB decompression cap, size/signature validation). Changed: OneTimePassword and Bitcoin/BitcoinCash/Litecoin payload generators rewritten (proper issuer/label escaping, SHA256/SHA512, culture-invariant amounts). Fixed: explicit ECI modes now encode payload bytes matching the declared designator; ASCII renderer no longer transposes output; PDF page tree is spec-compliant; Url payload handles uppercase schemes; vCard/MeCard ADR field order follows RFC 2426; CalendarEvent/ContactData dates are culture-invariant and UTC times carry the Z suffix; WiFi emits standard lowercase nopass; OTP labels without an issuer are no longer dropped.</PackageReleaseNotes>
		<PackageLicenseExpression>BSD-3-Clause</PackageLicenseExpression>
	</PropertyGroup>
	<ItemGroup>
	  <None Include="..\readme.md">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	</ItemGroup>
</Project>
